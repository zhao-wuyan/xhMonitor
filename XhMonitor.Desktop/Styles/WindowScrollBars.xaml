<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowScrollBarTrackBrush" Color="#1824303A"/>
    <SolidColorBrush x:Key="WindowScrollBarThumbBrush" Color="#7F93A4BC"/>
    <SolidColorBrush x:Key="WindowScrollBarThumbHoverBrush" Color="#AFC8D7EC"/>
    <SolidColorBrush x:Key="WindowScrollBarThumbPressedBrush" Color="#DCEBFFF5"/>
    <SolidColorBrush x:Key="WindowScrollBarThumbBorderBrush" Color="#2F2E3A4A"/>

    <Style x:Key="WindowScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Rectangle Fill="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowScrollBarThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="Background" Value="{StaticResource WindowScrollBarThumbBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="ThumbChrome"
                            Margin="2"
                            CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource WindowScrollBarThumbBorderBrush}"
                            BorderThickness="1"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource WindowScrollBarThumbHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource WindowScrollBarThumbPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="WindowVerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Width="{TemplateBinding Width}" Background="Transparent" SnapsToDevicePixels="True">
            <Border Margin="0,4,0,4"
                    CornerRadius="5"
                    Background="{StaticResource WindowScrollBarTrackBrush}"
                    Opacity="0.88"/>
            <Track x:Name="PART_Track"
                   IsDirectionReversed="True"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource WindowScrollBarPageButtonStyle}"
                                  Command="{x:Static ScrollBar.PageUpCommand}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource WindowScrollBarThumbStyle}"
                           Background="{TemplateBinding Foreground}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource WindowScrollBarPageButtonStyle}"
                                  Command="{x:Static ScrollBar.PageDownCommand}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="WindowHorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Height="{TemplateBinding Height}" Background="Transparent" SnapsToDevicePixels="True">
            <Border Margin="4,0,4,0"
                    CornerRadius="5"
                    Background="{StaticResource WindowScrollBarTrackBrush}"
                    Opacity="0.88"/>
            <Track x:Name="PART_Track"
                   IsDirectionReversed="False"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource WindowScrollBarPageButtonStyle}"
                                  Command="{x:Static ScrollBar.PageLeftCommand}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource WindowScrollBarThumbStyle}"
                           Background="{TemplateBinding Foreground}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource WindowScrollBarPageButtonStyle}"
                                  Command="{x:Static ScrollBar.PageRightCommand}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="{StaticResource WindowScrollBarTrackBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WindowScrollBarThumbBrush}"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="Template" Value="{StaticResource WindowVerticalScrollBarTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="10"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="Template" Value="{StaticResource WindowHorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
